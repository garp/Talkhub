{
    "extends": "airbnb-base",
    "env": {
      "node": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-underscore-dangle": "off",
      "max-len": ["error", { "code": 200 }],
      "consistent-return": ["off"] ,
      "no-plusplus": "off"
    }
  }
  